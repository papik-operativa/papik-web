{
  "_meta": {
    "description": "Registre de mapeig de slugs CA <-> ES <-> EN per al nou build PAPIK. Font de veritat per a hreflang automatic + sitemap generation. Mantenir actualitzat si es renomenen pagines.",
    "version": "1.0",
    "updated": "2026-04-27",
    "domain": "https://papik.cat",
    "languages": ["ca", "es", "en"],
    "default_language": "ca",
    "url_strategy": "vercel cleanUrls=true serveix /<slug> des de /<slug>.html"
  },

  "_pending_renames": {
    "description": "Renames pendents que el dev ha d'aplicar a S3 per coherencia idiomatica. Slugs ES haurien d'estar en castella, no catala.",
    "renames_es": [
      { "from": "es/construccio.html", "to": "es/construccion.html" },
      { "from": "es/promocio.html", "to": "es/promocion.html" },
      { "from": "es/rehabilitacio.html", "to": "es/rehabilitacion.html" },
      { "from": "es/patrimonis.html", "to": "es/patrimonios.html" },
      { "from": "es/nosaltres.html", "to": "es/nosotros.html" },
      { "from": "es/projectes.html", "to": "es/proyectos.html" },
      { "from": "es/usuaris.html", "to": "es/usuarios.html" },
      { "from": "es/pressupost.html", "to": "es/presupuesto.html" }
    ],
    "note": "Aplicar abans del 1 juny. Ajustar slug-mapping.json en consequencia."
  },

