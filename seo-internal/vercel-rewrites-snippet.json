  "_python_generator": "# Save as gen_redirects.py and run: python3 gen_redirects.py\n# Reads redirect-map-full.csv, writes vercel-rewrites-snippet.json\nimport csv, json, sys, pathlib\n\nROOT = pathlib.Path(__file__).resolve().parent\nCSV  = ROOT / 'redirect-map-full.csv'\nOUT  = ROOT / 'vercel-rewrites-snippet.json'\n\ndef strip_trailing_slash(u):\n    return u.rstrip('/') if u != '/' else u\n\ndef strip_html(p):\n    return p[:-5] if p.endswith('.html') else p\n\nrewrites, redirects = [], []\nwith CSV.open(encoding='utf-8') as f:\n    reader = csv.reader(f)\n    headers = next(reader)\n    for row in reader:\n        if not row or row[0].startswith('#'): continue\n        old, action, dest, lang, prio, *_ = row + [''] * 6\n        old = strip_trailing_slash(old.strip())\n        dest = strip_trailing_slash(strip_html(dest.strip()))\n        if action == 'rewrite':\n            rewrites.append({'source': old, 'destination': dest})\n        elif action in ('301', 'deprecate'):\n            redirects.append({'source': old, 'destination': dest, 'permanent': True})\n\nOUT.write_text(json.dumps({'rewrites': rewrites, 'redirects': redirects}, indent=2, ensure_ascii=False))\nprint(f'wrote {len(rewrites)} rewrites + {len(redirects)} redirects -> {OUT}')\n"
}
