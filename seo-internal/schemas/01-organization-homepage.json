{
  "_doc": "Schema JSON-LD per a la homepage. Combina HomeAndConstructionBusiness + WebSite (amb SearchAction) + ItemList dels 4 serveis. Anar dins d'una <script type='application/ld+json'> al <head> de /, /es/ i /en/. Reemplaçar els camps marcats amb {{ ... }} amb valors reals abans de publicar.",
  "_replace_before_publish": [
    "{{LOGO_URL}}", "{{HERO_IMAGE_URL}}", "{{LATITUDE}}", "{{LONGITUDE}}",
    "{{LINKEDIN_URL}}", "{{INSTAGRAM_URL}}", "{{YOUTUBE_URL}}"
  ],

  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "HomeAndConstructionBusiness",
      "@id": "https://papik.cat/#org",
      "name": "PAPIK Group",
      "alternateName": ["PAPIK", "Papik Cases Passives"],
      "url": "https://papik.cat",
      "logo": {
        "@type": "ImageObject",
        "url": "{{LOGO_URL}}",
        "width": 512,
        "height": 512
      },
      "image": "{{HERO_IMAGE_URL}}",
      "description": "Construcció, promoció, rehabilitació i patrimoni · Cases sostenibles a Catalunya, Balears i Andorra des de 1994.",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Carrer Sort 34",
        "addressLocality": "Sant Cugat del Vallès",
        "postalCode": "08172",
        "addressRegion": "Barcelona",
        "addressCountry": "ES"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "{{LATITUDE}}",
        "longitude": "{{LONGITUDE}}"
      },
      "telephone": "+34935906074",
      "email": "info@papik.cat",
      "foundingDate": "1994",
      "founder": {
        "@type": "Person",
        "name": "Papik Fisas Moreno"
      },
      "areaServed": [
        { "@type": "AdministrativeArea", "name": "Catalunya" },
        { "@type": "AdministrativeArea", "name": "Illes Balears" },
        { "@type": "Country", "name": "Andorra" }
      ],
      "knowsAbout": [
        "Passivhaus",
        "Construcció sostenible",
        "Rehabilitació energètica",
        "Eskimohaus",
        "Edificis de consum gairebé nul (nZEB)",
        "EnerPHit"
      ],
      "sameAs": [
        "{{LINKEDIN_URL}}",
        "{{INSTAGRAM_URL}}",
        "{{YOUTUBE_URL}}"
      ]
    },
    {
      "@type": "WebSite",
      "@id": "https://papik.cat/#website",
      "url": "https://papik.cat",
      "name": "PAPIK Group",
      "description": "Cases sostenibles, naturalment.",
      "publisher": { "@id": "https://papik.cat/#org" },
      "inLanguage": ["ca-ES", "es-ES", "en-US"]
    },
    {
      "@type": "ItemList",
      "name": "Serveis de PAPIK Group",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "url": "https://papik.cat/construccio",
          "name": "Construcció"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "url": "https://papik.cat/promocio",
          "name": "Promoció"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "url": "https://papik.cat/rehabilitacio",
          "name": "Rehabilitació"
        },
        {
          "@type": "ListItem",
          "position": 4,
          "url": "https://papik.cat/patrimonis",
          "name": "Patrimonis"
        }
      ]
    }
  ]
}
