{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/download-pdf.py":      { "maxDuration": 60 },
    "api/analitzar-plans.py":   { "maxDuration": 60 },
    "api/chat-configurador.py": { "maxDuration": 60 },
    "api/chat-pressupost.py":   { "maxDuration": 60 },
    "api/notificar-equip.py":   { "maxDuration": 15 },
    "api/resum-setmanal.py":    { "maxDuration": 30 }
  },
  "crons": [
    { "path": "/api/resum-setmanal", "schedule": "0 6 * * 1" }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/pressupost",
      "permanent": false
    },
    {
      "source": "/((?!pressupost|atelier|planols|api|css|js|fonts|img|PAPIK|cursor\\.js|robots\\.txt|favicon).*)",
      "destination": "/pressupost",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
